<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>皮膚濕度壓力指數 - 全台摘要</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container { max-width: 500px; margin: 0 auto; }
        .card {
            background: white;
            border-radius: 30px;
            padding: 25px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        h1 { font-size: 24px; margin-bottom: 8px; color: #333; }
        .subtitle { color: #666; font-size: 13px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid #eee; }
        .loading { text-align: center; padding: 40px; color: #999; }
        .result { margin-top: 10px; }
        .date-badge {
            background: #667eea;
            color: white;
            display: inline-block;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            margin-bottom: 15px;
        }
        .city-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #f0f0f0;
        }
        .city-name { font-weight: 500; font-size: 16px; }
        .shock-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 500;
        }
        .shock-low { background: #00CC00; color: white; }
        .shock-medium { background: #FFCC00; color: #333; }
        .shock-high { background: #FF6600; color: white; }
        .shock-danger { background: #FF0000; color: white; }
        .legend {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 12px;
            margin: 20px 0;
            padding-top: 15px;
            border-top: 1px solid #eee;
        }
        .legend-item { display: flex; align-items: center; gap: 5px; font-size: 12px; }
        .legend-color { width: 16px; height: 16px; border-radius: 50%; }
        .footer {
            text-align: center;
            font-size: 11px;
            color: #999;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 1px solid #eee;
        }
        .refresh-btn {
            background: #667eea;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 30px;
            font-size: 14px;
            cursor: pointer;
            width: 100%;
            margin-top: 15px;
        }
        .refresh-btn:hover { background: #5a67d8; }
        .last-update { text-align: center; font-size: 11px; color: #aaa; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <h1>🌡️💧 皮膚濕度壓力指數</h1>
            <div class="subtitle">
                室內基準：冷氣房 26℃ | 依據 Denda et al. (2002)
            </div>
            
            <div id="result" class="result">
                <div class="loading">📊 載入中...</div>
            </div>
            
            <button class="refresh-btn" onclick="loadData()">🔄 更新資料</button>
            <div class="last-update" id="lastUpdate"></div>
            
            <div style="text-align: center; margin-top: 20px;">
                <a href="https://line.me/R/ti/p/@922uktxh" target="_blank" style="display: inline-block; background: #06C755; color: white; text-decoration: none; padding: 10px 20px; border-radius: 30px; font-size: 13px;">
                    📱 加入 LINE 好友接收每日推播
                </a>
            </div>
            <div class="footer">
                📊 中央氣象署 | 室內濕度推算：工研院終極公式 R²≈0.85
            </div>
        </div>
    </div>

    <script>
        // 👇 請替換成你的 Render 服務網址
        const API_BASE = 'https://line-bot-v9q8.onrender.com';
        
        async function loadData() {
            const resultDiv = document.getElementById('result');
            resultDiv.innerHTML = '<div class="loading">📊 載入中...</div>';
            
            try {
                const response = await fetch(`${API_BASE}/api/all-cities-summary`);
                const data = await response.json();
                
                if (data.success) {
                    displayResults(data);
                } else {
                    resultDiv.innerHTML = `<div class="loading">⚠️ ${data.message}</div>`;
                }
            } catch (error) {
                resultDiv.innerHTML = `<div class="loading">⚠️ 連線錯誤：${error.message}</div>`;
            }
        }
        
        function displayResults(data) {
            const date = new Date();
            const dateStr = `${date.getMonth()+1}/${date.getDate()}`;
            
            let html = `<div style="text-align: center;"><span class="date-badge">📅 ${dateStr} 全台預報</span></div>`;
            
            for (const city of data.data) {
                let shockClass = '';
                if (city.shockLevel === '低衝擊') shockClass = 'shock-low';
                else if (city.shockLevel === '中衝擊') shockClass = 'shock-medium';
                else if (city.shockLevel === '高衝擊') shockClass = 'shock-high';
                else shockClass = 'shock-danger';
                
                html += `
                    <div class="city-row">
                        <span class="city-name">${city.city}</span>
                        <span class="shock-badge ${shockClass}">${city.shockEmoji} ${city.shockLevel}</span>
                    </div>
                `;
            }
            
            html += `
                <div class="legend">
                    <div class="legend-item"><div class="legend-color" style="background: #00CC00;"></div><span>低衝擊</span></div>
                    <div class="legend-item"><div class="legend-color" style="background: #FFCC00;"></div><span>中衝擊</span></div>
                    <div class="legend-item"><div class="legend-color" style="background: #FF6600;"></div><span>高衝擊</span></div>
                    <div class="legend-item"><div class="legend-color" style="background: #FF0000;"></div><span>危險衝擊</span></div>
                </div>
                <div style="background: #f0f2f5; border-radius: 16px; padding: 12px; margin-top: 10px;">
                    <div style="font-size: 12px; color: #666;">
                        💡 濕度衝擊 = 室外濕度變化幅度<br>
                        📖 依據 Denda et al. (2002)：濕度驟降破壞皮膚屏障
                    </div>
                </div>
            `;
            
            resultDiv.innerHTML = html;
            const now = new Date();
            document.getElementById('lastUpdate').innerHTML = `最後更新：${now.toLocaleTimeString()}`;
        }
        
        loadData();
        setInterval(loadData, 30 * 60 * 1000);
    </script>
</body>
</html>
